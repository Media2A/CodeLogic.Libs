<Project>
  <!-- Shared NuGet metadata for all CL.* libraries -->
  <PropertyGroup>
    <Authors>Media2A</Authors>
    <Copyright>Copyright © 2026 Media2A</Copyright>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/Media2A/CodeLogic.Libs</PackageProjectUrl>
    <RepositoryUrl>https://github.com/Media2A/CodeLogic.Libs</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
  </PropertyGroup>

  <!-- Include the repo-level LICENSE in every package -->
  <ItemGroup>
    <None Include="$(MSBuildThisFileDirectory)LICENSE" Pack="true" PackagePath="/" />
  </ItemGroup>

  <!--
    ProjectReference → PackageReference swap for NuGet packing.
    CI clones CodeLogic locally so 'dotnet build' works, but 'dotnet pack'
    must produce a correct package dependency.

    By default, the packed .nuspec pins the *exact* referenced version
    (e.g. CodeLogic=3.2.4), which forces every lib to re-release each time
    CodeLogic bumps. We override that to a floating range using a
    wildcard so libs declare "CodeLogic 3.2.*" and keep working across
    patch bumps without needing a new lib release.
  -->
  <PropertyGroup>
    <CodeLogicPackageVersion Condition="'$(CodeLogicPackageVersion)' == ''">3.2.*</CodeLogicPackageVersion>
  </PropertyGroup>

  <!-- Rewrite the ProjectReference version during pack so the .nuspec
       gets a floating 3.2.* dependency on CodeLogic instead of an exact
       pin to whatever version the workspace happens to have locally. -->
  <Target Name="OverrideCodeLogicPackageVersion"
          BeforeTargets="_GetProjectReferenceVersions">
    <ItemGroup>
      <_ProjectReferencesWithVersions
        Condition="'%(_ProjectReferencesWithVersions.PackageId)' == 'CodeLogic'">
        <ProjectVersion>$(CodeLogicPackageVersion)</ProjectVersion>
      </_ProjectReferencesWithVersions>
    </ItemGroup>
  </Target>
</Project>
