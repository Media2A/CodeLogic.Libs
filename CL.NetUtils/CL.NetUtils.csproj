<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>CL.NetUtils</RootNamespace>
    <AssemblyName>CL.NetUtils</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>13</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Version>3.1.0</Version>
    <PackageId>CodeLogic.NetUtils</PackageId>
    <PackageTags>dns;dnsbl;geoip;geolocation</PackageTags>
    <Authors>Media2A</Authors>
    <Description>DNSBL blacklist checking and IP geolocation services for CodeLogic 3 applications</Description>
    <NoWarn>CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="MaxMind.GeoIP2" Version="5.*" />
    <PackageReference Include="SharpCompress" Version="0.*" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="../../CodeLogic/src/CodeLogic.csproj" />
  </ItemGroup>
</Project>