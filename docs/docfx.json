{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "CL.Common/CL.Common.csproj",
            "CL.GitHelper/CL.GitHelper.csproj",
            "CL.Mail/CL.Mail.csproj",
            "CL.MySQL2/CL.MySQL2.csproj",
            "CL.NetUtils/CL.NetUtils.csproj",
            "CL.PostgreSQL/CL.PostgreSQL.csproj",
            "CL.SQLite/CL.SQLite.csproj",
            "CL.SocialConnect/CL.SocialConnect.csproj",
            "CL.StorageS3/CL.StorageS3.csproj",
            "CL.SystemStats/CL.SystemStats.csproj",
            "CL.TwoFactorAuth/CL.TwoFactorAuth.csproj",
            "CL.GameNetQuery/CL.GameNetQuery.csproj"
          ],
          "src": "../"
        }
      ],
      "dest": "api",
      "disableGitFeatures": false,
      "disableDefaultFilter": false
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**.yml", "api/index.md"]
      },
      {
        "files": ["articles/**.md", "articles/**/toc.yml", "toc.yml", "*.md"]
      }
    ],
    "resource": [
      {
        "files": ["images/**"]
      }
    ],
    "dest": "../docs-output",
    "globalMetadata": {
      "_appTitle": "CodeLogic Libraries",
      "_appLogoPath": "images/logo.svg",
      "_appFaviconPath": "images/favicon.ico",
      "_enableSearch": true,
      "_appFooter": "Copyright &copy; 2026 Media2A. Built with <a href='https://dotnet.github.io/docfx'>DocFX</a>.",
      "_appName": "CodeLogic Libraries"
    },
    "template": ["default", "modern"],
    "sitemap": {
      "baseUrl": "https://media2a.github.io/CodeLogic.Libs"
    },
    "xref": [],
    "exportRawModel": false,
    "exportViewModel": false
  }
}
